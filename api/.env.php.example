<?php
/**
 * Environment Configuration Example
 * 
 * Copy this file to .env.php and fill in your actual values.
 * DO NOT commit .env.php to version control!
 * 
 * For production on Hostinger, set these in the control panel instead.
 */

// SMTP Configuration (Hostinger)
putenv('SMTP_HOST=smtp.hostinger.com');
putenv('SMTP_PORT=587');
putenv('SMTP_USER=info@provizient.com');
putenv('SMTP_PASSWORD=your-email-password-here');
putenv('SMTP_FROM_EMAIL=ProVizient <info@provizient.com>');

// Notification email (where inquiries are sent)
putenv('NOTIFICATION_EMAIL=info@provizient.com');
?>
