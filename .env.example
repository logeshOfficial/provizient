# ===========================================
# ProVizient — Environment Variables Reference
# Copy this file to .env.local for local dev
# ===========================================

# --- Site ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="ProVizient"

# --- Google Analytics (optional) ---
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# --- Demo Mode ---
# Set to "true" to simulate form submissions without sending real emails.
# Set to "false" or omit for production.
NEXT_PUBLIC_DEMO_MODE="false"

# ===========================================
# SMTP Email (required for production)
# Azure Static Web Apps → Configuration → Application settings
# ===========================================

# Hostinger SMTP Configuration
# Use info@provizient.com for both sending and receiving

# SMTP server hostname (Hostinger)
SMTP_HOST="smtp.hostinger.com"

# SMTP port: 587 for STARTTLS (recommended), 465 for SSL
SMTP_PORT="587"

# Set to "true" only when using port 465 (SSL). Leave "false" for 587 STARTTLS.
SMTP_SECURE="false"

# SMTP auth credentials - Use your info@provizient.com email credentials
# (DO NOT commit real values - only set in Azure Application settings)
SMTP_USER="info@provizient.com"
SMTP_PASSWORD="your-email-password-here"

# Sender identity shown in the From: header
SMTP_FROM_EMAIL="ProVizient <info@provizient.com>"

# Notification mailbox — receives every contact inquiry
# (Same as SMTP_USER for simplified setup)
NOTIFICATION_EMAIL="info@provizient.com"
