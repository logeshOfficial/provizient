# Database
DATABASE_URL="postgresql://user:password@localhost:5432/provizient?schema=public"

# NextAuth
AUTH_SECRET="generate-a-secure-random-string-here"
AUTH_URL="http://localhost:3000"

# Admin credentials (used for initial seed)
ADMIN_EMAIL="admin@provizient.com"
ADMIN_PASSWORD="change-this-password"

# Resend Email
RESEND_API_KEY="re_xxxxxxxxxxxx"
RESEND_FROM_EMAIL="ProVizient <noreply@provizient.com>"
NOTIFICATION_EMAIL="contact@provizient.com"

# Cloudinary
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Google Analytics
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# Site
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="ProVizient"
